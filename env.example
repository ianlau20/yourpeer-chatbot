# =============================================================================
# YourPeer Chatbot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets. The .gitignore already
# excludes it. This .env.example file is safe to commit.
# =============================================================================


# ---------------------------------------------------------------------------
# Required — the app won't work without these
# ---------------------------------------------------------------------------

# PostgreSQL connection string for the Streetlives database (read-only).
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# Anthropic API key — powers all LLM features (conversation, slot extraction,
# crisis detection, eval suite). Get one at https://console.anthropic.com/
# Without this, the system still works but falls back to regex-only mode.
ANTHROPIC_API_KEY=


# ---------------------------------------------------------------------------
# Required in production — optional for local dev
# ---------------------------------------------------------------------------

# Random string for HMAC-signing session tokens. Prevents session forgery.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# If unset: tokens are unsigned (fine for local dev, NOT for production).
SESSION_SECRET=

# Random string for admin API authentication. Protects /admin/api/* endpoints.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If unset: admin endpoints are open (fine for local dev, NOT for production).
# Must be set on BOTH the backend and frontend services (the Next.js proxy
# forwards it as a Bearer token).
ADMIN_API_KEY=

# Comma-separated list of allowed CORS origins.
# Production: set to your frontend URL (e.g., https://yourpeer-chatbot.onrender.com)
# If unset: defaults to http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ---------------------------------------------------------------------------
# Frontend (set in frontend-next/.env.local for local dev,
#           or as env vars on the frontend Render service)
# ---------------------------------------------------------------------------

# URL of the backend API.
# Local dev: http://localhost:8000
# Production (private service): http://yourpeer-chatbot-api:PORT
#   (find the internal URL in the Render dashboard after deploying)
# CHAT_BACKEND_URL=http://localhost:8000


# ---------------------------------------------------------------------------
# Rate limiting — all optional, sensible defaults shown
# ---------------------------------------------------------------------------

# Per-session limits (primary — caps individual conversations)
# RATE_LIMIT_SESSION_PER_MIN=12
# RATE_LIMIT_SESSION_PER_HOUR=60
# RATE_LIMIT_SESSION_PER_DAY=200

# Per-IP limits (secondary — safety net for shared WiFi at shelters)
# Set conservatively: 30/min supports ~15 concurrent users at peak.
# RATE_LIMIT_IP_PER_MIN=30
# RATE_LIMIT_IP_PER_HOUR=150
# RATE_LIMIT_IP_PER_DAY=500

# Feedback endpoint limit
# RATE_LIMIT_FEEDBACK_PER_MIN=10
